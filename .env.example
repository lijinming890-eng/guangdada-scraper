# ===== 广大大账号 (必填) =====
GDD_USERNAME=your_guangdada_username
GDD_PASSWORD=your_guangdada_password

# ===== 飞书应用 (定时推送到飞书时必填) =====
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_USER_OPEN_ID=your_feishu_user_open_id

# ===== Kimi AI 分析 (使用 --analyze 时必填) =====
KIMI_API_KEY=your_kimi_api_key

# ===== OpenClaw (使用 OpenClaw 技能时自动读取) =====
# 如果通过 OpenClaw 使用，飞书凭据会自动从 ~/.openclaw/openclaw.json 读取
# 无需在此设置 FEISHU_APP_ID / FEISHU_APP_SECRET
